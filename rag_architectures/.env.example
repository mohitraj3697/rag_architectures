# Copy this file to `.env` and fill in your key.

# Required — get one at https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Optional — defaults shown. Swap to the 120b model for higher quality/cost.
GROQ_MODEL=openai/gpt-oss-20b
GROQ_MODEL_LARGE=openai/gpt-oss-120b

# Optional — any sentence-transformers model on Hugging Face works here.
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
