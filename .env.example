# Groq API Key (get key at https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_groq_api_key_here

# Groq Model (default: openai/gpt-oss-20b, large: openai/gpt-oss-120b)
GROQ_MODEL=openai/gpt-oss-20b
GROQ_MODEL_LARGE=openai/gpt-oss-120b

# HuggingFace Embeddings Model (default: sentence-transformers/all-MiniLM-L6-v2)
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
